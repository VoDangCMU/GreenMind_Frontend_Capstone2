{
  "name": "green_mindmap_be",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migration:create": "ts-node -r tsconfig-paths/register ./src/runner/migration_create.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register ./src/runner/migration_generate.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/infrastructure/database.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/infrastructure/database.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/infrastructure/database.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "db:drop": "yarn typeorm schema:drop -d src/infrastructure/database.ts",
    "db:run": "yarn typeorm migration:run -d src/infrastructure/database.ts",
    "db:generate": "yarn typeorm migration:generate -d src/infrastructure/database.ts",
    "jest": "jest",
    "test": "jest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.52.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-logs": "^0.52.0",
    "@opentelemetry/sdk-metrics": "^1.25.0",
    "@opentelemetry/sdk-trace-node": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "decomment": "^0.9.5",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "jest": "^30.1.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "redis": "^5.5.6",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "typeorm": "^0.3.25",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
